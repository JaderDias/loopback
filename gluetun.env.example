# Copy to gluetun.env and fill in your ProtonVPN WireGuard credentials.
# See https://github.com/qdm12/gluetun-wiki/tree/main/setup#setup

VPN_SERVICE_PROVIDER=custom
VPN_TYPE=wireguard
WIREGUARD_PUBLIC_KEY=YOUR_PUBLIC_KEY_HERE
WIREGUARD_PRIVATE_KEY=YOUR_PRIVATE_KEY_HERE
WIREGUARD_ADDRESSES=10.2.0.2/32
WIREGUARD_ENDPOINT_IP=YOUR_VPN_SERVER_IP
WIREGUARD_ENDPOINT_PORT=51820
VPN_DNS_ADDRESS=10.2.0.1
VPN_PORT_FORWARDING=on
VPN_PORT_FORWARDING_PROVIDER=protonvpn
VPN_PORT_FORWARDING_UP_COMMAND=/bin/sh -c 'echo {{PORTS}} > /var/lib/loopback/vpn_port'
TZ=Europe/Berlin
UPDATER_PERIOD=24h
